{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LLOYD-11/cloud_security_misconfiguration_lab/schemas/storage-environment-v1.0.schema.json",
  "title": "Simplified Storage Environment v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["account_id", "buckets"],
  "properties": {
    "account_id": { "type": "string", "pattern": "^[0-9]{12}$" },
    "buckets": {
      "type": "array",
      "items": { "$ref": "#/$defs/bucket" }
    }
  },
  "$defs": {
    "stringOrStringList": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "principal": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            ]
          }
        }
      ]
    },
    "policyStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect"],
      "properties": {
        "sid": { "type": "string" },
        "effect": { "enum": ["Allow", "Deny"] },
        "principal": { "$ref": "#/$defs/principal" },
        "not_principal": { "$ref": "#/$defs/principal" },
        "action": { "$ref": "#/$defs/stringOrStringList" },
        "not_action": { "$ref": "#/$defs/stringOrStringList" },
        "resource": { "$ref": "#/$defs/stringOrStringList" },
        "not_resource": { "$ref": "#/$defs/stringOrStringList" },
        "condition": { "type": "object" }
      },
      "allOf": [
        {
          "oneOf": [
            { "required": ["principal"] },
            { "required": ["not_principal"] }
          ]
        },
        {
          "oneOf": [
            { "required": ["action"] },
            { "required": ["not_action"] }
          ]
        },
        {
          "oneOf": [
            { "required": ["resource"] },
            { "required": ["not_resource"] }
          ]
        }
      ]
    },
    "bucket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "public_access_block",
        "acl",
        "bucket_policy",
        "encryption",
        "versioning"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 3 },
        "region": { "type": "string", "minLength": 1 },
        "object_ownership": {
          "enum": [
            "BucketOwnerEnforced",
            "BucketOwnerPreferred",
            "ObjectWriter"
          ]
        },
        "public_access_block": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "block_public_acls",
            "ignore_public_acls",
            "block_public_policy",
            "restrict_public_buckets"
          ],
          "properties": {
            "block_public_acls": { "type": "boolean" },
            "ignore_public_acls": { "type": "boolean" },
            "block_public_policy": { "type": "boolean" },
            "restrict_public_buckets": { "type": "boolean" }
          }
        },
        "acl": {
          "type": "object",
          "additionalProperties": false,
          "required": ["grants"],
          "properties": {
            "grants": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["grantee", "permission"],
                "properties": {
                  "grantee": { "type": "string", "minLength": 1 },
                  "permission": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "bucket_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statements"],
          "properties": {
            "statements": {
              "type": "array",
              "items": { "$ref": "#/$defs/policyStatement" }
            }
          }
        },
        "encryption": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "algorithm": { "type": "string", "minLength": 1 },
            "key_id": { "type": "string", "minLength": 1 }
          }
        },
        "versioning": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["Enabled", "Suspended", "Disabled"] }
          }
        }
      }
    }
  }
}
