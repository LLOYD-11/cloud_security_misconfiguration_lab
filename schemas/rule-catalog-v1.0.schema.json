{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LLOYD-11/cloud_security_misconfiguration_lab/schemas/rule-catalog-v1.0.schema.json",
  "title": "Cloud Security Detection Rule Catalog v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "frameworks", "rule_count", "rules"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "frameworks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/framework"
      }
    },
    "rule_count": {
      "type": "integer",
      "minimum": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "source_url"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "framework",
        "control_id",
        "title",
        "relationship",
        "url",
        "rationale"
      ],
      "properties": {
        "framework": {
          "type": "string",
          "minLength": 1
        },
        "control_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "relationship": {
          "enum": ["direct", "related"]
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "module",
        "title",
        "summary",
        "default_severity",
        "allowed_severities",
        "confidence",
        "confidence_basis",
        "mappings"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^(IAM|STO|NET|CLD)-[0-9]{3}$"
        },
        "module": {
          "enum": ["iam", "storage", "network", "cloudtrail"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "default_severity": {
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "allowed_severities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["critical", "high", "medium", "low", "info"]
          }
        },
        "confidence": {
          "enum": ["high", "medium", "low"]
        },
        "confidence_basis": {
          "type": "string",
          "minLength": 1
        },
        "mappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/mapping"
          }
        }
      }
    }
  }
}
