{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LLOYD-11/cloud_security_misconfiguration_lab/schemas/incidents-v1.0.schema.json",
  "title": "Cloud Security Incidents File v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "incident_count", "incidents"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "incident_count": { "type": "integer", "minimum": 0 },
    "incidents": {
      "type": "array",
      "items": { "$ref": "#/$defs/incident" }
    }
  },
  "$defs": {
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "incident": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "incident_id",
        "severity",
        "confidence",
        "module",
        "category",
        "title",
        "actor",
        "source_ip",
        "first_seen",
        "last_seen",
        "event_count",
        "finding_count",
        "rule_ids",
        "event_ids",
        "resources",
        "summary",
        "recommended_actions",
        "references"
      ],
      "properties": {
        "incident_id": {
          "type": "string",
          "pattern": "^CTI-[0-9A-F]{12}$"
        },
        "severity": {
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "confidence": {
          "enum": ["low", "medium", "high"]
        },
        "module": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "source_ip": { "type": "string", "minLength": 1 },
        "first_seen": { "type": "string", "format": "date-time" },
        "last_seen": { "type": "string", "format": "date-time" },
        "event_count": { "type": "integer", "minimum": 1 },
        "finding_count": { "type": "integer", "minimum": 1 },
        "rule_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "event_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "resources": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "summary": { "type": "string", "minLength": 1 },
        "recommended_actions": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "references": { "$ref": "#/$defs/nonEmptyUniqueStrings" }
      }
    }
  }
}
