{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LLOYD-11/cloud_security_misconfiguration_lab/schemas/aws-fixture-manifest-v1.0.schema.json",
  "title": "Sanitized AWS Fixture Manifest v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_name",
    "description",
    "origin",
    "fixtures"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "dataset_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "origin": { "const": "synthetic" },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fixture" }
    }
  },
  "$defs": {
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "service",
        "fixture_type",
        "format",
        "operations",
        "contract",
        "shape_references",
        "account_id",
        "regions",
        "observed_from",
        "observed_to",
        "origin",
        "sanitization",
        "expected_rule_ids",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^sample_data/aws/(?:cloudtrail|ec2|iam|s3)/[^/]+$"
        },
        "service": {
          "enum": ["cloudtrail", "ec2", "iam", "s3"]
        },
        "fixture_type": {
          "enum": [
            "native-aws-response",
            "assembled-aws-evidence",
            "derived-assessment"
          ]
        },
        "format": {
          "enum": ["csv", "json", "json-gzip"]
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "contract": {
          "type": "string",
          "pattern": "^(?:schemas/[a-z0-9.-]+\\.schema\\.json|cloud_security_lab/normalizers/iam\\.py)$"
        },
        "shape_references": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          }
        },
        "account_id": {
          "type": "string",
          "pattern": "^[0-9]{12}$"
        },
        "regions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "observed_from": {
          "type": "string",
          "format": "date-time",
          "pattern": "(?:Z|\\+00:00)$"
        },
        "observed_to": {
          "type": "string",
          "format": "date-time",
          "pattern": "(?:Z|\\+00:00)$"
        },
        "origin": { "const": "synthetic" },
        "sanitization": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "expected_rule_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?:IAM|STO|NET|CLD)-[0-9]{3}$"
          }
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
