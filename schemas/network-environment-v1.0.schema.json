{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LLOYD-11/cloud_security_misconfiguration_lab/schemas/network-environment-v1.0.schema.json",
  "title": "Simplified Network Environment v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["account_id", "security_groups"],
  "properties": {
    "account_id": { "type": "string", "pattern": "^[0-9]{12}$" },
    "security_groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/securityGroup" }
    }
  },
  "$defs": {
    "port": {
      "type": ["integer", "null"],
      "minimum": -1,
      "maximum": 65535
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "from_port", "to_port", "cidr"],
      "properties": {
        "protocol": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer" }
          ]
        },
        "from_port": { "$ref": "#/$defs/port" },
        "to_port": { "$ref": "#/$defs/port" },
        "cidr": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "securityGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "inbound_rules", "outbound_rules"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "inbound_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/rule" }
        },
        "outbound_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/rule" }
        }
      }
    }
  }
}
