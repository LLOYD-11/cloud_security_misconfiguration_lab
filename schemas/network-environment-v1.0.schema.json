{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LLOYD-11/cloud_security_misconfiguration_lab/schemas/network-environment-v1.0.schema.json",
  "title": "Simplified Network Environment v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["account_id", "security_groups"],
  "properties": {
    "account_id": { "type": "string", "pattern": "^[0-9]{12}$" },
    "security_groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/securityGroup" }
    }
  },
  "$defs": {
    "port": {
      "type": ["integer", "null"],
      "minimum": -1,
      "maximum": 65535
    },
    "reachabilityDirection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scope", "evidence"],
      "properties": {
        "status": {
          "enum": ["reachable", "not_reachable", "inconclusive"]
        },
        "scope": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "resource_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reachability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "observed_at", "ingress", "egress"],
      "properties": {
        "method": {
          "enum": [
            "aws-network-access-analyzer",
            "aws-reachability-analyzer",
            "manual-topology-review",
            "other"
          ]
        },
        "observed_at": { "type": "string", "format": "date-time" },
        "ingress": { "$ref": "#/$defs/reachabilityDirection" },
        "egress": { "$ref": "#/$defs/reachabilityDirection" }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "from_port", "to_port"],
      "oneOf": [
        { "required": ["cidr"] },
        { "required": ["peer_type", "peer_id"] }
      ],
      "properties": {
        "protocol": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "integer" }
          ]
        },
        "from_port": { "$ref": "#/$defs/port" },
        "to_port": { "$ref": "#/$defs/port" },
        "cidr": { "type": "string", "minLength": 1 },
        "peer_type": { "enum": ["prefix_list", "security_group"] },
        "peer_id": { "type": "string", "minLength": 1 },
        "peer_account_id": { "type": "string", "pattern": "^[0-9]{12}$" },
        "peer_vpc_id": { "type": "string", "minLength": 1 },
        "peering_status": { "type": "string", "minLength": 1 },
        "peer_group_name": { "type": "string", "minLength": 1 },
        "peer_vpc_peering_connection_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "securityGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "inbound_rules", "outbound_rules"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "owner_id": { "type": "string", "pattern": "^[0-9]{12}$" },
        "vpc_id": { "type": "string", "minLength": 1 },
        "arn": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "reachability": { "$ref": "#/$defs/reachability" },
        "inbound_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/rule" }
        },
        "outbound_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/rule" }
        }
      }
    }
  }
}
