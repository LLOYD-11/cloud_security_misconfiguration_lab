{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LLOYD-11/cloud_security_misconfiguration_lab/schemas/attack-timeline-v1.0.schema.json",
  "title": "Cloud Security Attack Timeline v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_cloudtrail_finding_count",
    "source_incident_count",
    "entry_count",
    "omission_count",
    "entries",
    "omissions"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "source_cloudtrail_finding_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_incident_count": { "type": "integer", "minimum": 0 },
    "entry_count": { "type": "integer", "minimum": 0 },
    "omission_count": { "type": "integer", "minimum": 0 },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    },
    "omissions": {
      "type": "array",
      "items": { "$ref": "#/$defs/omission" }
    }
  },
  "$defs": {
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "first_seen",
        "last_seen",
        "severity",
        "confidence",
        "activity_type",
        "rule_id",
        "title",
        "actor",
        "source_ip",
        "event_names",
        "event_ids",
        "resource",
        "incident_ids",
        "observation",
        "significance"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "pattern": "^TLN-[0-9A-F]{12}$"
        },
        "first_seen": {
          "type": "string",
          "format": "date-time",
          "pattern": "(Z|\\+00:00)$"
        },
        "last_seen": {
          "type": "string",
          "format": "date-time",
          "pattern": "(Z|\\+00:00)$"
        },
        "severity": {
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "confidence": {
          "enum": ["high", "medium", "low", "not-assessed"]
        },
        "activity_type": {
          "enum": [
            "account-access",
            "identity-protection-change",
            "network-access-change",
            "data-access-change",
            "authorization-change",
            "discovery-and-probing",
            "credential-persistence",
            "trust-relationship-change",
            "monitoring-impairment",
            "destructive-impact",
            "other-observed-activity"
          ]
        },
        "rule_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "source_ip": { "type": "string", "minLength": 1 },
        "event_names": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "event_ids": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
        "resource": { "type": "string", "minLength": 1 },
        "incident_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^CTI-[0-9A-F]{12}$"
          }
        },
        "observation": { "type": "string", "minLength": 1 },
        "significance": { "type": "string", "minLength": 1 }
      }
    },
    "omission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "resource", "reason"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "resource": { "type": "string", "minLength": 1 },
        "reason": {
          "enum": [
            "missing-timestamp",
            "invalid-timestamp",
            "invalid-time-range",
            "missing-event-id"
          ]
        }
      }
    }
  }
}
