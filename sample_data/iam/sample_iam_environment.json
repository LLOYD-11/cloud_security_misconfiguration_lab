          "age_days": 12,
          "last_used_days": 1
        }
      ],
      "attached_policies": [
        {
          "policy_name": "BroadS3WritePolicy",
          "statements": [
            {
              "sid": "BroadS3",
              "effect": "Allow",
              "action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
              ],
              "resource": "arn:aws:s3:::company-data-*/*"
            }
          ]
        }
      ]
    },
    {
      "name": "readonly-analyst",
      "mfa_enabled": true,
      "access_keys": [],
      "attached_policies": [
        {
          "policy_name": "ReadOnlyReports",
          "statements": [
            {
              "sid": "ReadReports",
              "effect": "Allow",
              "action": [
                "s3:GetObject",
                "cloudwatch:GetMetricData"
              ],
              "resource": [
                "arn:aws:s3:::company-reports/*",
                "arn:aws:cloudwatch:ap-southeast-2:111122223333:metric/*"
              ],
              "condition": {
                "Bool": {
                  "aws:MultiFactorAuthPresent": "true"
                }
              }
            }
          ]
        }
