      "name": "third-party-audit-role",
      "trust_policy": {
        "statements": [
          {
            "sid": "ExternalAccountTrust",
            "effect": "Allow",
            "principal": {
              "AWS": "arn:aws:iam::999988887777:root"
            },
            "action": "sts:AssumeRole"
          }
        ]
      },
      "attached_policies": [
        {
          "policy_name": "AuditReadOnly",
          "statements": [
            {
              "sid": "AuditRead",
              "effect": "Allow",
